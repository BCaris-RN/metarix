# =========================
# MetaRix public repo safety
# =========================

# --- Secrets / env ---
.env
.env.*
*.env
*.secret
*.secrets
*.key
*.pem
*.p12
*.crt
*.cer
*.jks
*.keystore
secrets/
private/
credentials/
auth/
tokens/
*.token
*.oauth
*.service-account.json
firebase-adminsdk*.json

# --- Local config / machine-specific ---
.local/
.local
*.local
*.override
*.bak
*.tmp
*.swp
*.orig

# --- OS junk ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE / editor ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
*.iml

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.venv/
venv/
env/
ENV/
dist/
build/
*.egg-info/

# --- Node / JS / TS ---
node_modules/
.npm/
.pnpm-store/
.next/
.nuxt/
.svelte-kit/
coverage/
*.tsbuildinfo

# --- Dart / Flutter ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
.pub-cache/
build/
.flutter-plugins-dependencies
ios/Flutter/ephemeral/
ios/Pods/
ios/.symlinks/
macos/Pods/
linux/flutter/ephemeral/
windows/flutter/ephemeral/

# --- Android / Gradle ---
.gradle/
android/.gradle/
android/local.properties
android/key.properties
*.apk
*.aab

# --- Xcode / Apple ---
DerivedData/
*.xcworkspace
*.xcuserstate
*.xcuserdata/

# --- Generated artifacts / bundles ---
SEMANTIC_BUNDLE.txt
SEMANTIC_BUNDLE_*.txt
semantic_bundle/
*.semantic.txt

# --- Runtime evidence / exports / reports ---
evidence/
exports/
artifacts/
reports/generated/
tmp/
temp/

# --- Database / local test state ---
*.sqlite
*.sqlite3
*.db
*.mdb

# --- Archives ---
*.zip
*.tar
*.gz
*.7z
*.rar

# --- Media / binary outputs that should not be casually committed ---
*.mp4
*.mov
*.avi
*.psd
*.ai
*.sketch
*.fig

# --- Test accounts / sample dumps / raw social exports ---
sample_exports/
raw_exports/
customer_exports/
social_exports/
fixtures/private/

# --- Optional keepers ---
# If you later decide a generated artifact is intentionally public,
# remove it from this ignore list explicitly rather than weakening the whole file.

# === MetaRix local-only proprietary boundaries ===
# Local-only runtime boundaries begin below.
# Check git status before any commit.

# === MetaRix local-only runtime boundary ===
.env
.env.local
.env.*.local
secrets/
local_runtime/
local_data/
local_exports/
local_reports/
local_media/
local_watch/
local_tokens/
local_logs/
*.db
*.sqlite
*.sqlite3
*.log
runtime_user_config.json
