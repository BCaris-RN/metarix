{
  "contract": "metarix.publish_boundedness_rules",
  "version": "0.1.0",
  "principles": {
    "scheduled_not_publish_eligible": true,
    "publish_eligible_requires_approval": true,
    "publish_eligible_requires_evidence": true,
    "publish_eligible_requires_supported_channel_action": true
  },
  "enforcement_order": [
    "channel_capability",
    "action_permission",
    "approval_requirement",
    "evidence_requirement",
    "publish_posture"
  ],
  "rules": [
    {
      "id": "scheduled_state_is_not_publish_eligible",
      "when": {
        "content_state": "scheduled"
      },
      "assert": {
        "publish_eligible": false
      },
      "deny_reason": "scheduled_requires_separate_publish_gate"
    },
    {
      "id": "publish_eligible_requires_supported_channel_action",
      "when": {
        "target_posture": "publish_eligible"
      },
      "requires": {
        "channel_capabilities": [
          "schedule_supported",
          "publish_supported"
        ],
        "allowed_action": "publish_attempt"
      },
      "deny_reason": "channel_action_not_supported"
    },
    {
      "id": "publish_eligible_requires_approval_and_evidence",
      "when": {
        "target_posture": "publish_eligible"
      },
      "requires": {
        "approval_satisfied": true,
        "required_evidence_profile": "publish_eligibility"
      },
      "deny_reason": "approval_or_evidence_incomplete"
    },
    {
      "id": "preview_and_demo_modes_block_publish_attempts",
      "when": {
        "execution_mode": [
          "preview",
          "demo"
        ]
      },
      "assert": {
        "publish_attempt_allowed": false
      },
      "deny_reason": "execution_mode_blocks_publish"
    }
  ]
}
